{
  "name": "filebouncer",
  "version": "0.0.0",
  "description": "Lightweight file upload security layer for Node.js. Detects ZIP slip, ZIP bombs, MIME spoofing, CSV injection, and other structural file abuse.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "security",
    "file-upload",
    "zip-slip",
    "zip-bomb",
    "mime",
    "csv-injection",
    "scanner",
    "validation"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ramzi-Abidi/file-detection-engine.git"
  },
  "bugs": {
    "url": "https://github.com/Ramzi-Abidi/file-detection-engine/issues"
  },
  "homepage": "https://github.com/Ramzi-Abidi/file-detection-engine#readme",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "dependencies": {
    "file-type": "^21.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
